{
  "appId": "com.pdfreader.mac",
  "productName": "PDF Reader",
  "artifactName": "PDFReader-${version}-mac-x64.${ext}",
  "icon": "icons/icon.png",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "asar": true,
  "asarUnpack": ["**/node_modules/pdfjs-dist/**"],
  "mac": {
    "target": [
      {
        "target": "zip",
        "arch": ["x64"]
      },
      {
        "target": "dmg",
        "arch": ["x64"]
      }
    ],
    "category": "public.app-category.productivity"
  }
}
